{
  "name": "caixu-dev-workspace",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "install:bootstrap": "node scripts/install-caixu.mjs",
    "smoke:agent": "node scripts/agent-driven-smoke.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^24.7.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
